# ---------------------------------------------------------------------------
# ERP system — environment variables
# Copy this file to `.env` at the repo root and adjust values for your machine.
# The NestJS API (apps/api) loads this root .env via @nestjs/config.
# ---------------------------------------------------------------------------

# Node environment
NODE_ENV=development

# --- Database (PostgreSQL via Prisma) --------------------------------------
# Matches the credentials in docker-compose.yml
DATABASE_URL="postgresql://erp:erp@localhost:5432/erp?schema=public"

# --- Redis (reserved for a later real-time / pub-sub phase) -----------------
REDIS_URL="redis://localhost:6379"

# --- API server -------------------------------------------------------------
PORT=3001
# Origin of the Next.js web app, used for CORS (credentials are enabled).
WEB_ORIGIN="http://localhost:3000"

# --- JWT / auth -------------------------------------------------------------
# Generate strong random values for production, e.g. `openssl rand -base64 48`
JWT_ACCESS_SECRET="dev-access-secret-change-me"
JWT_REFRESH_SECRET="dev-refresh-secret-change-me"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
# Set to "true" only when serving the refresh cookie over HTTPS (production).
COOKIE_SECURE=false

# --- Seed defaults (dev only — change the admin password after first login) --
SEED_COMPANY_NAME="Demo Company"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="ChangeMe123!"

# --- Web app (Next.js) ------------------------------------------------------
# Optional: base URL the browser uses to reach the API. Defaults to
# http://localhost:3001 in code if unset. If you override it, place it in
# apps/web/.env.local (Next.js only auto-loads env files from its own dir).
NEXT_PUBLIC_API_URL="http://localhost:3001"
