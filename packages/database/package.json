{
  "name": "@erp/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, generated client wrapper, and seed script for the ERP database.",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "prisma"],
  "prisma": {
    "schema": "prisma/schema",
    "seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "db:generate": "dotenv -e ../../.env -- prisma generate",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset",
    "db:seed": "dotenv -e ../../.env -- ts-node prisma/seed.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.16.1",
    "bcrypt": "^5.1.1"
  },
  "devDependencies": {
    "@erp/config": "workspace:*",
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^20.14.10",
    "dotenv-cli": "^7.4.2",
    "prisma": "^5.16.1",
    "rimraf": "^5.0.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
